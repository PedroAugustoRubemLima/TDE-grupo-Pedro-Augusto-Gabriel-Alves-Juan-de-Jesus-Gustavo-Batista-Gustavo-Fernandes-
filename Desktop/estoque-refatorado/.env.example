# ============================================================
# Sistema de Estoque - Laticínios
# .env.example — copie para .env e preencha com seus valores
# NUNCA suba o arquivo .env para o Git
# ============================================================

# Banco de dados
DB_USER=root
DB_PASS=sua_senha_do_banco

# JWT — gere uma string aleatória longa (min 32 chars)
# Sugestão: openssl rand -base64 48
JWT_SECRET=troque-isso-por-uma-chave-longa-e-aleatoria-em-producao

# AES — deve ter EXATAMENTE 16 caracteres
AES_SECRET=TroqueCom16Chars

# CORS — domínios permitidos (separados por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:8080,https://seudominio.com
